{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently \"vite\" \"wait-on http://localhost:8080 && electron .\"",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "desktop:build": "vite build && electron-builder --mac --win",
    "desktop:build:mac": "vite build && electron-builder --mac",
    "desktop:build:win": "vite build && electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "main": "electron/main.ts",
  "build": {
    "appId": "com.yourcompany.apitool",
    "productName": "ApiTool",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
